# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# 개인용 로컬 메모 (서버 IP, SSH 키 경로 등 환경별 정보)
*.local.md

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# database
/data/*.db
/data/*.db-wal
/data/*.db-shm

# uploads (user-generated)
/public/uploads/thumbnails/*
/public/uploads/attachments/*
!/public/uploads/thumbnails/.gitkeep
!/public/uploads/attachments/.gitkeep
